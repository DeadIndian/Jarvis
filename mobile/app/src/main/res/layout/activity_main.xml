<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#101114">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jarvis - Phase 1"
            android:textColor="#EAF2FF"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#1B1D22"
            android:padding="12dp"
            android:text="Status: booting"
            android:textColor="#DCE3EE"
            android:textSize="14sp" />

        <Button
            android:id="@+id/wakeButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Trigger Wake" />

        <EditText
            android:id="@+id/commandInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#1B1D22"
            android:hint="Say or type command (e.g., what time is it)"
            android:textColorHint="#8791A1"
            android:inputType="text"
            android:padding="12dp"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/runCommandButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Run Command" />

        <Button
            android:id="@+id/speakCommandButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Speak Command" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Custom Commands"
            android:textColor="#C8D5EA"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/customKeywordsInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#1B1D22"
            android:hint="Keywords / phrases (comma separated)"
            android:inputType="text"
            android:padding="12dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#8791A1" />

        <Spinner
            android:id="@+id/customActionSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/customResponseInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#1B1D22"
            android:hint="Response text (for reply action)"
            android:inputType="text"
            android:padding="12dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#8791A1" />

        <Button
            android:id="@+id/saveCustomCommandButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Save Custom Command" />

        <TextView
            android:id="@+id/customCommandsPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#15181E"
            android:padding="12dp"
            android:text="No custom commands yet"
            android:textColor="#AFC0D9"
            android:textSize="13sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Set Mode"
            android:textColor="#C8D5EA"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/modeActiveButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Active"
                android:textSize="12sp" />

            <Button
                android:id="@+id/modeWorkButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:text="Work"
                android:textSize="12sp" />

            <Button
                android:id="@+id/modeSleepButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:text="Sleep"
                android:textSize="12sp" />

            <Button
                android:id="@+id/modeOffButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:text="Off"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/helpText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#15181E"
            android:padding="12dp"
            android:text="Try: time, open settings, remind me, help. You can also save custom keyword commands above."
            android:textColor="#AFC0D9"
            android:textSize="13sp" />

    </LinearLayout>
</ScrollView>
