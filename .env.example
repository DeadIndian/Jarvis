# Jarvis local development config
# Copy this file to .env and fill in values.

# Hugging Face token (read scope) for gated model download.
JARVIS_HF_TOKEN=

# LLM backend mode: local-only | hybrid | cloud-only | gemini | litert
JARVIS_LLM_BACKEND=local-only

# Optional Gemini API key for hybrid/cloud modes.
JARVIS_GEMINI_API_KEY=

# Optional override for model artifact directory on device.
JARVIS_LITERT_MODEL_DIR=
