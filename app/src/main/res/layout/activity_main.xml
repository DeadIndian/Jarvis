<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/assistantRootScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:ignore="Autofill,ButtonStyle,HardcodedText,UnusedResources">

    <LinearLayout
        android:id="@+id/assistantRootContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="State: IDLE"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#2196F3" />

        <TextView
            android:id="@+id/modelReadyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Model: Not Initialized"
            android:textColor="#f44336"
            android:textSize="14sp"
            android:textStyle="italic" />

        <TextView
            android:id="@+id/selectModelLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Select Model"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/modelSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp" />

        <LinearLayout
            android:id="@+id/modelActionRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/useModelButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Use Model"
                android:backgroundTint="#4CAF50"
                android:textColor="#ffffff" />

            <Button
                android:id="@+id/manageModelsButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Manage Models" />
        </LinearLayout>

        <!-- Hidden Model Management Section -->
        <LinearLayout
            android:id="@+id/modelManagementSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="12dp"
            android:padding="8dp"
            android:background="#f0f0f0">

            <TextView
                android:id="@+id/modelStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Model Info"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/modelStatusDetailText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Status: —"
                android:textSize="12sp" />

            <ProgressBar
                android:id="@+id/downloadProgressBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                style="?android:attr/progressBarStyleHorizontal"
                android:progress="0"
                android:max="100" />

            <TextView
                android:id="@+id/downloadProgressText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text=""
                android:textSize="11sp"
                android:gravity="center"
                android:visibility="gone" />

            <TextView
                android:id="@+id/installedModelsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Installed models: 0"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/refreshModelsButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    style="?android:attr/buttonBarButtonStyle"
                    android:textSize="12sp"
                    android:text="Refresh" />

                <Button
                    android:id="@+id/downloadModelButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    style="?android:attr/buttonBarButtonStyle"
                    android:textSize="12sp"
                    android:text="Download" />

                <Button
                    android:id="@+id/deleteModelButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    style="?android:attr/buttonBarButtonStyle"
                    android:textSize="12sp"
                    android:text="Delete" />
            </LinearLayout>

        </LinearLayout>

        <TextView
            android:id="@+id/modelErrorText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="#d32f2f"
            android:textSize="12sp"
            android:visibility="gone" />

        <View
            android:id="@+id/mainDivider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="#cccccc" />

        <EditText
            android:id="@+id/inputText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Type command..."
            android:inputType="text" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/sendButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Send" />
            <Button
                android:id="@+id/voiceButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="Voice" />
        </LinearLayout>

        <TextView
            android:id="@+id/ttsVoiceLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="TTS Voice"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/ttsGenderSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/debugControlsLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Debug Controls"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/debugControlsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/powerButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="12sp"
                android:text="Power Hold" />
            <Button
                android:id="@+id/wakeWordButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:textSize="12sp"
                android:text="Wake" />
            <Button
                android:id="@+id/timeoutButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:textSize="12sp"
                android:text="Timeout" />
        </LinearLayout>

        <Button
            android:id="@+id/exportClassifierDataButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Export Classifier Data" />

        <TextView
            android:id="@+id/logText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:padding="8dp"
            android:background="#f9f9f9"
            android:text="Logs:\n"
            android:textSize="12sp"
            android:fontFamily="monospace" />
    </LinearLayout>
</ScrollView>
